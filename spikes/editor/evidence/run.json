{
  "schemaVersion": 1,
  "runtime": {
    "node": "22.23.0"
  },
  "commands": [
    {
      "id": "root_install",
      "command": "CI=1 NPM_CONFIG_USERCONFIG=/dev/null pnpm install --frozen-lockfile",
      "exitCode": 0,
      "outputSummary": [
        "lockfile frozen and up to date"
      ]
    },
    {
      "id": "spike_install",
      "command": "CI=1 NPM_CONFIG_USERCONFIG=/dev/null pnpm --dir spikes/editor install --frozen-lockfile",
      "exitCode": 0,
      "outputSummary": [
        "lockfile frozen and up to date"
      ]
    },
    {
      "id": "typecheck",
      "command": "NPM_CONFIG_USERCONFIG=/dev/null pnpm --dir spikes/editor -r run typecheck",
      "exitCode": 0,
      "outputSummary": [
        "typecheck blocknote=done fixture=done oracle=done tiptap=done"
      ]
    },
    {
      "id": "fixture_test",
      "command": "NPM_CONFIG_USERCONFIG=/dev/null pnpm --dir spikes/editor --filter @spike/fixture test",
      "exitCode": 0,
      "outputSummary": [
        "vitest files=3/3",
