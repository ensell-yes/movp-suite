{
  "name": "@movp/graphql",
  "version": "0.1.1",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --target node20 --out-dir dist"
  },
  "dependencies": {
    "@movp/core-schema": "workspace:*",
    "@movp/domain": "workspace:*",
    "@pothos/core": "^4.3.0",
    "@pothos/plugin-complexity": "^4.1.0",
    "@pothos/plugin-dataloader": "^4.1.0",
    "@supabase/supabase-js": "^2.45.0",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.10.0"
  },
  "devDependencies": {
    "vitest": "^3.2.6"
  },
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
