{
  "name": "@movp/search",
  "version": "0.1.1",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./gte-small": "./src/gte-small.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/gte-small.ts --format esm --dts --sourcemap --clean --target node20 --out-dir dist"
  },
  "dependencies": {
    "@movp/domain": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.6"
  },
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./gte-small": {
        "types": "./dist/gte-small.d.ts",
        "import": "./dist/gte-small.js"
      }
    }
  }
}
