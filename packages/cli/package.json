{
  "name": "@movp/cli",
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "movp": "./src/bin.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --sourcemap --clean --target node20 --out-dir dist"
  },
  "dependencies": {
    "@movp/codegen": "workspace:*",
    "@movp/core-schema": "workspace:*",
    "@movp/domain": "workspace:*",
    "@movp/flows": "workspace:*",
    "@movp/obs": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "vitest": "^3.2.6",
    "@types/node": "^26.0.1"
  },
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
      "movp": "./dist/bin.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
