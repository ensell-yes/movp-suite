{
  "name": "movp-suite",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "codegen": "tsx scripts/codegen.ts",
    "docs:manifest": "tsx scripts/emit-docs-manifest.ts",
    "docs:reference": "tsx docs-site/scripts/gen-dsl-reference.ts",
    "docs:build": "pnpm --filter @movp/docs-site build",
    "check:docs-freshness": "node scripts/check-docs-freshness.mjs",
    "check:docs-manifest": "tsx scripts/check-docs-manifest.ts",
    "check:docs": "pnpm check:task-cms-contracts && node scripts/check-docs-presence.mjs && node scripts/check-agent-configs.mjs",
    "check:packages": "node scripts/check-package-artifacts.mjs",
    "check:publishable-versions": "node scripts/check-publishable-versions.mjs",
    "check:ci-wiring": "node scripts/check-ci-wiring.mjs",
    "check:verdaccio-crm": "bash fixtures/verdaccio-crm-lite/gate.sh",
    "check:verdaccio-gallery": "bash -c 'set -euo pipefail; d=$(mktemp -d); trap \"rm -rf $d\" EXIT; bash fixtures/verdaccio-gallery/pack.sh $d; for t in crm-lite marketing-site support-desk knowledge-base; do ARTIFACTS_DIR=$d bash fixtures/verdaccio-gallery/gate.sh $t; done'",
    "test:version-gate": "node --test scripts/test/guarded-read.test.mjs scripts/test/check-publishable-versions.test.mjs scripts/test/check-ci-wiring.test.mjs",
    "check:release-preflight": "node scripts/check-release-preflight.mjs",
    "check:demo-seed": "node scripts/check-demo-seed.mjs",
    "check:quickstart-docs": "node scripts/check-quickstart-docs.mjs",
    "check:onboarding-debt": "node scripts/check-onboarding-debt.mjs",
    "check:supabase-ports": "node scripts/check-supabase-port-strategy.mjs",
    "check:supabase-cli-pins": "node --test scripts/check-supabase-cli-pins.test.mjs && node scripts/check-supabase-cli-pins.mjs",
    "check:agent-configs": "node scripts/check-agent-configs.mjs",
    "check:task-cms-contracts": "node --test scripts/check-task-cms-contracts.test.mjs && node scripts/check-task-cms-contracts.mjs",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "bootstrap": "node scripts/bootstrap.mjs",
    "test": "turbo run test",
    "test:event-catalog": "node scripts/check-event-catalog.mjs",
    "test:forward-only-migrations": "node scripts/check-forward-only-migrations.mjs",
    "test:graphql-shape": "pnpm --filter @movp/graphql exec vitest run schema",
    "test:jobs": "pnpm --filter @movp/flows exec vitest run jobs",
    "test:redaction": "pnpm --filter @movp/obs exec vitest run emit",
    "gate:metadata-consistency": "bash scripts/gate-metadata-consistency.sh",
    "typecheck": "turbo run typecheck",
    "build": "pnpm --filter \"./packages/*\" -r run build"
  },
  "devDependencies": {
    "@movp/codegen": "workspace:*",
    "@movp/core-schema": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "verdaccio": "^6"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=7.28.0",
      "ws": ">=8.21.0",
      "yaml": ">=2.8.3",
      "vite": ">=6.4.3",
      "esbuild": "^0.25.0",
      "js-yaml": ">=4.2.0",
      "qs": ">=6.15.2",
      "uuid": "^11.1.1"
    }
  }
}
