---
interface Props {
  name: 'admin' | 'campaigns' | 'chevron' | 'content' | 'inbox' | 'logout' | 'menu' | 'notes' | 'profile' | 'search' | 'security' | 'segments' | 'tasks' | 'tokens' | 'workflows'
  size?: number
}

const { name, size = 20 } = Astro.props
---
<svg
  class="icon"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {name === 'menu' && <><path d="M4 7h16M4 12h16M4 17h16" /></>}
  {name === 'notes' && <><path d="M6 3h9l3 3v15H6z" /><path d="M15 3v4h4M9 11h6M9 15h6" /></>}
  {name === 'tasks' && <><path d="M9 5h11M9 12h11M9 19h11" /><path d="m4 5 1.5 1.5L8 4M4 12l1.5 1.5L8 11M4 19l1.5 1.5L8 18" /></>}
  {name === 'content' && <><rect x="4" y="3" width="16" height="18" rx="2" /><path d="M8 8h8M8 12h8M8 16h5" /></>}
  {name === 'campaigns' && <><path d="M4 13V8l13-4v13L4 13Z" /><path d="M8 14v5a2 2 0 0 1-4 0v-6M17 8a4 4 0 0 1 0 5" /></>}
  {name === 'segments' && <><circle cx="8" cy="8" r="3" /><circle cx="16" cy="8" r="3" /><path d="M3 20a5 5 0 0 1 10 0M11 20a5 5 0 0 1 10 0" /></>}
  {name === 'workflows' && <><circle cx="6" cy="6" r="2" /><circle cx="18" cy="6" r="2" /><circle cx="12" cy="18" r="2" /><path d="M8 6h8M7 8l4 8M17 8l-4 8" /></>}
  {name === 'inbox' && <><path d="M4 4h16v16H4z" /><path d="m4 14 4-4h8l4 4M8 14l2 3h4l2-3" /></>}
  {name === 'search' && <><circle cx="11" cy="11" r="7" /><path d="m16 16 4 4" /></>}
  {name === 'profile' && <><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></>}
  {name === 'security' && <><path d="M12 3 5 6v5c0 4.6 2.8 8 7 10 4.2-2 7-5.4 7-10V6z" /><path d="M9.5 12 11 13.5l3.5-4" /></>}
  {name === 'tokens' && <><circle cx="8" cy="15" r="4" /><path d="m11 12 8-8M15 4h4v4" /></>}
  {name === 'admin' && <><circle cx="9" cy="8" r="3" /><path d="M3 19a6 6 0 0 1 12 0M17 11l1 1 2-2M17 16l1 1 2-2" /></>}
  {name === 'logout' && <><path d="M10 4H5v16h5M14 8l4 4-4 4M18 12H9" /></>}
  {name === 'chevron' && <><path d="m8 10 4 4 4-4" /></>}
</svg>
