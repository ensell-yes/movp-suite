---
import Base from '../../layouts/Base.astro'
import AuthFailure from '../../components/states/AuthFailure.astro'
import ErrorRetry from '../../components/states/ErrorRetry.astro'
import EmptyState from '../../components/states/EmptyState.astro'
import { readServerEnv } from '../../lib/env.ts'
import { gqlRequest } from '../../lib/graphql.ts'
import { getSessionToken } from '../../lib/session.ts'
import {
  CREATE_INGEST_KEY_MUTATION,
  INGEST_KEYS_QUERY,
  REVOKE_INGEST_KEY_MUTATION,
  ROTATE_INGEST_KEY_MUTATION,
  type IngestKeyRow,
  type IngestKeySecret,
} from '../../lib/admin-queries.ts'

type KeysData = { ingestKeys: IngestKeyRow[] }

const token = getSessionToken(Astro.cookies)
let state: 'auth' | 'error' | 'empty' | 'ok' = 'auth'
let keys: IngestKeyRow[] = []
let notice = ''
let formError = ''
let oneTimeKey: IngestKeySecret | null = null

if (token) {
  Astro.response.headers.set('Cache-Control', 'no-store')
  state = 'ok'
  const { graphqlEndpoint, workspaceId } = readServerEnv()

  if (Astro.request.method === 'POST') {
    const form = await Astro.request.formData()
    const action = String(form.get('action') ?? '')
    if (action === 'create') {
      const result = await gqlRequest<{ createIngestKey: IngestKeySecret }>(
        { endpoint: graphqlEndpoint, token },
        CREATE_INGEST_KEY_MUTATION,
        { workspaceId, label: String(form.get('label') ?? '') },
      )
      if (!result.ok && result.code === 'auth_error') state = 'auth'
      else if (!result.ok) formError = result.message ?? 'Could not create ingest key.'
      else {
        oneTimeKey = result.data.createIngestKey
        notice = 'Ingest key created.'
      }
    } else if (action === 'rotate') {
      if (form.get('confirm_rotate') !== '1') {
        formError = 'Confirm key rotation before continuing.'
      } else {
        const result = await gqlRequest<{ rotateIngestKey: IngestKeySecret }>(
          { endpoint: graphqlEndpoint, token },
          ROTATE_INGEST_KEY_MUTATION,
          { workspaceId, keyId: String(form.get('keyId') ?? '') },
        )
        if (!result.ok && result.code === 'auth_error') state = 'auth'
        else if (!result.ok) formError = result.message ?? 'Could not rotate ingest key.'
        else {
          oneTimeKey = result.data.rotateIngestKey
          notice = 'Ingest key rotated.'
        }
      }
    } else if (action === 'revoke') {
      if (form.get('confirm_revoke') !== '1') {
        formError = 'Confirm key revocation before continuing.'
      } else {
        const result = await gqlRequest(
          { endpoint: graphqlEndpoint, token },
          REVOKE_INGEST_KEY_MUTATION,
          { workspaceId, keyId: String(form.get('keyId') ?? '') },
        )
        if (!result.ok && result.code === 'auth_error') state = 'auth'
        else if (!result.ok) formError = result.message ?? 'Could not revoke ingest key.'
        else notice = 'Ingest key revoked.'
      }
    }
  }

  if (state !== 'auth') {
    const result = await gqlRequest<KeysData>({ endpoint: graphqlEndpoint, token }, INGEST_KEYS_QUERY, { workspaceId })
    if (!result.ok && result.code === 'auth_error') state = 'auth'
    else if (!result.ok) state = 'error'
    else {
      keys = result.data.ingestKeys
      state = keys.length === 0 ? 'empty' : 'ok'
    }
  }
}
---
<Base title="Ingest API Keys">
  <h1 tabindex="-1" id="admin-api-keys-heading">Ingest API Keys</h1>
  <p><a href="/admin/members">Members</a></p>
  {state === 'auth' && <AuthFailure resource="ingest API keys" />}
  {state === 'error' && <ErrorRetry message="Could not load ingest API keys." retryHref={Astro.url.pathname} />}
  {notice && <p role="status" data-testid="admin-notice">{notice}</p>}
  {formError && <p role="alert" data-testid="admin-form-error">{formError}</p>}

  {oneTimeKey && (
    <section data-testid="ingest-key-secret" role="status" aria-labelledby="ingest-key-secret-heading">
      <h2 id="ingest-key-secret-heading">One-time API key</h2>
      <p>Store this key now. It will not be shown again.</p>
      <code>{oneTimeKey.rawKey}</code>
      <script is:inline>
        history.replaceState(null, '', location.pathname)
      </script>
    </section>
  )}

  {(state === 'ok' || state === 'empty') && (
    <section aria-labelledby="create-ingest-key-heading">
      <h2 id="create-ingest-key-heading">Create key</h2>
      <form method="post" data-testid="ingest-key-create-form">
        <input type="hidden" name="action" value="create" />
        <label>
          Label
          <input name="label" required />
        </label>
        <button type="submit">Create ingest key</button>
      </form>
    </section>
  )}

  {state === 'empty' && <EmptyState message="No ingest API keys yet." />}

  {state === 'ok' && (
    <table data-testid="ingest-keys">
      <thead>
        <tr><th>Label</th><th>Status</th><th>Created</th><th>Actions</th></tr>
      </thead>
      <tbody>
        {keys.map((key) => (
          <tr>
            <td>{key.label ?? key.id}</td>
            <td>{key.active ? 'active' : 'inactive'}</td>
            <td>{key.created_at}</td>
            <td>
              <form method="post">
                <input type="hidden" name="action" value="rotate" />
                <input type="hidden" name="keyId" value={key.id} />
                <label>
                  <input
                    type="checkbox"
                    name="confirm_rotate"
                    value="1"
                    aria-label={`Confirm rotation of ingest key ${key.label ?? key.id}`}
                  />
                  Confirm rotation
                </label>
                <button type="submit" aria-label={`Rotate ingest key ${key.label ?? key.id}`}>Rotate key</button>
              </form>
              <form method="post">
                <input type="hidden" name="action" value="revoke" />
                <input type="hidden" name="keyId" value={key.id} />
                <label>
                  <input
                    type="checkbox"
                    name="confirm_revoke"
                    value="1"
                    aria-label={`Confirm revocation of ingest key ${key.label ?? key.id}`}
                  />
                  Confirm revocation
                </label>
                <button type="submit" aria-label={`Revoke ingest key ${key.label ?? key.id}`}>Revoke key</button>
              </form>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</Base>
