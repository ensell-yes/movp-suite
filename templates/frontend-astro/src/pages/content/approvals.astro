---
import Base from '../../layouts/Base.astro'
import AuthFailure from '../../components/states/AuthFailure.astro'
import ErrorRetry from '../../components/states/ErrorRetry.astro'
import EmptyState from '../../components/states/EmptyState.astro'
import { readServerEnv } from '../../lib/env.ts'
import { getSessionToken } from '../../lib/session.ts'
import { gqlRequest } from '../../lib/graphql.ts'
import {
  APPROVALS_PAGE_QUERY,
  DECIDE_MUTATION,
  type ContentPage,
  type ContentApprovalRow,
} from '../../lib/content-queries.ts'

const token = getSessionToken(Astro.cookies)
let state: 'auth' | 'error' | 'empty' | 'ok' = 'auth'
let approvals: ContentApprovalRow[] = []
let labels = new Map<string, string>()
let notice = ''

if (token) {
  const { graphqlEndpoint, workspaceId } = readServerEnv()
  if (Astro.request.method === 'POST') {
    const form = await Astro.request.formData()
    const approvalId = String(form.get('approvalId') ?? '')
    const vote = String(form.get('vote') ?? '')
    const r = await gqlRequest({ endpoint: graphqlEndpoint, token }, DECIDE_MUTATION, { approvalId, vote })
    if (!r.ok && r.code === 'auth_error') state = 'auth'
    else if (!r.ok) state = 'error'
    else notice = vote === 'reject' ? 'Rejected' : 'Approved'
  }

  if (state !== 'error' && !(Astro.request.method === 'POST' && state === 'auth')) {
    const r = await gqlRequest<{ contentApprovals: ContentApprovalRow[]; content: ContentPage }>(
      { endpoint: graphqlEndpoint, token },
      APPROVALS_PAGE_QUERY,
      { workspaceId },
    )
    if (!r.ok && r.code === 'auth_error') state = 'auth'
    else if (!r.ok) state = 'error'
    else {
      approvals = r.data.contentApprovals
      labels = new Map(r.data.content.items.map((item) => [item.id, item.slug ?? item.id] as const))
      state = approvals.length === 0 ? 'empty' : 'ok'
    }
  }
}
---
<Base title="Content Approvals">
  <h1 tabindex="-1" id="content-approvals-heading">Content Approvals</h1>
  <p><a href="/content">Content</a> <a href="/content/calendar">Calendar</a></p>
  {state === 'auth' && <AuthFailure resource="content approvals" />}
  {state === 'error' && <ErrorRetry message="Could not load content approvals." retryHref={Astro.url.pathname} />}
  {state === 'empty' && <EmptyState message="No pending approvals." />}
  {notice && <p role="status">{notice}</p>}
  {state === 'ok' && (
    <section aria-labelledby="queue-heading" data-testid="content-approvals">
      <h2 id="queue-heading">Queue</h2>
      <ul>
        {approvals.map((approval) => (
          <li>
            <span>{approval.content_item_id ? labels.get(approval.content_item_id) ?? approval.content_item_id : approval.id}</span>
            <small> {approval.state ?? 'pending'}</small>
            <form method="post">
              <input type="hidden" name="approvalId" value={approval.id} />
              <button type="submit" name="vote" value="approve">Approve</button>
              <button type="submit" name="vote" value="reject">Reject</button>
            </form>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>
