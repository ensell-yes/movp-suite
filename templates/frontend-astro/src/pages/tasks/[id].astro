---
import Base from '../../layouts/Base.astro'
import AuthFailure from '../../components/states/AuthFailure.astro'
import ErrorRetry from '../../components/states/ErrorRetry.astro'
import EmptyState from '../../components/states/EmptyState.astro'
import { readServerEnv } from '../../lib/env.ts'
import { getSessionToken } from '../../lib/session.ts'
import { gqlRequest } from '../../lib/graphql.ts'
import { COMMENTS_QUERY, SUBTASKS_QUERY, TASK_QUERY, type CommentRow, type TaskPage, type TaskRow } from '../../lib/task-queries.ts'

const { id } = Astro.params
const token = getSessionToken(Astro.cookies)
let state: 'auth' | 'error' | 'empty' | 'ok' = 'auth'
let task: TaskRow | null = null
let comments: CommentRow[] = []
let subtasks: TaskPage['items'] = []

if (token) {
  const { graphqlEndpoint, workspaceId } = readServerEnv()
  const taskRes = await gqlRequest<{ task: TaskRow | null }>({ endpoint: graphqlEndpoint, token }, TASK_QUERY, { id })
  const commentsRes = await gqlRequest<{ comments: CommentRow[] }>(
    { endpoint: graphqlEndpoint, token },
    COMMENTS_QUERY,
    { workspaceId, entityType: 'task', entityId: id },
  )
  const subtasksRes = await gqlRequest<{ tasks: TaskPage }>(
    { endpoint: graphqlEndpoint, token },
    SUBTASKS_QUERY,
    { workspaceId, parentId: id },
  )
  if (!taskRes.ok || !commentsRes.ok || !subtasksRes.ok) state = 'error'
  else if (!taskRes.data.task) state = 'empty'
  else {
    task = taskRes.data.task
    comments = commentsRes.data.comments
    subtasks = subtasksRes.data.tasks.items
    state = 'ok'
  }
}
---
<Base title={task?.title ?? 'Task'}>
  {state === 'auth' && <AuthFailure resource="this task" />}
  {state === 'error' && <ErrorRetry message="Could not load this task." retryHref={Astro.url.pathname} />}
  {state === 'empty' && <EmptyState message="Task not found."><a href="/tasks">Back to tasks</a></EmptyState>}
  {state === 'ok' && task && (
    <article data-testid="task-detail">
      <h1 tabindex="-1" id="task-heading">{task.title}</h1>
      <p><small>Status {task.status_id}{task.due_date ? ` due ${task.due_date}` : ''}</small></p>
      {task.dependency_blocked && <p role="status">Blocked by dependency</p>}
      <section aria-labelledby="description-heading">
        <h2 id="description-heading">Description</h2>
        <p>{task.description ?? ''}</p>
      </section>
      <section aria-labelledby="discussion-heading" data-testid="task-comments">
        <h2 id="discussion-heading">Discussion</h2>
        {comments.length === 0 ? <p>No comments yet.</p> : (
          <ul>{comments.map((comment) => <li>{comment.body}</li>)}</ul>
        )}
      </section>
      <section aria-labelledby="subtasks-heading" data-testid="task-subtasks">
        <h2 id="subtasks-heading">Subtasks</h2>
        {subtasks.length === 0 ? <p>No subtasks.</p> : (
          <ul>{subtasks.map((subtask) => <li><a href={`/tasks/${subtask.id}`}>{subtask.title}</a></li>)}</ul>
        )}
      </section>
      <a href="/tasks">Back to tasks</a>
    </article>
  )}
</Base>
