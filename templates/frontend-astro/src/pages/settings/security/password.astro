---
import Base from '../../../layouts/Base.astro'
import AuthFailure from '../../../components/states/AuthFailure.astro'
import { PASSWORD_RECOVERY_COOKIE, SESSION_COOKIE } from '../../../lib/auth.ts'
import { readServerEnv } from '../../../lib/env.ts'
import { DISPLAY_NAME_COOKIE, getSessionToken } from '../../../lib/session.ts'
import { updatePassword, UserAccountError } from '../../../lib/user-account.ts'

Astro.response.headers.set('Cache-Control', 'no-store')

const token = getSessionToken(Astro.cookies)
const recoveryVerified = Astro.cookies.get(PASSWORD_RECOVERY_COOKIE)?.value === 'verified'
let state: 'auth' | 'ready' | 'error' = token && recoveryVerified ? 'ready' : 'auth'
let formError = ''

if (state === 'ready' && token && Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const password = String(form.get('password') ?? '')
  const confirmation = String(form.get('passwordConfirmation') ?? '')
  if (password.length < 8) formError = 'Use at least 8 characters.'
  else if (password !== confirmation) formError = 'Passwords do not match.'
  else {
    const env = readServerEnv()
    try {
      await updatePassword({ supabaseUrl: env.supabaseUrl, anonKey: env.supabaseAnonKey }, token, password)
      Astro.cookies.delete(SESSION_COOKIE, { path: '/' })
      Astro.cookies.delete(PASSWORD_RECOVERY_COOKIE, { path: '/settings/security/password' })
      Astro.cookies.delete(DISPLAY_NAME_COOKIE, { path: '/' })
      return Astro.redirect('/login?password=updated')
    } catch (error) {
      state = error instanceof UserAccountError && error.code === 'auth_error' ? 'auth' : 'error'
      formError = state === 'error' ? 'Could not update your password. Request a new recovery link and try again.' : ''
    }
  }
}
---
<Base title="Set a new password">
  <div class="account-page account-page--narrow">
    <header class="page-heading">
      <p class="eyebrow">Security</p>
      <h1 tabindex="-1" id="password-form-heading">Set a new password</h1>
    </header>
    {state === 'auth' && <AuthFailure resource="this password-reset session" />}
    {formError && <p class="form-error" role="alert" data-testid="password-error">{formError}</p>}
    {state === 'ready' && (
      <section class="account-card">
        <form method="post" aria-labelledby="password-form-heading" data-testid="password-form">
          <label class="form-field">
            <span>New password</span>
            <input name="password" type="password" minlength="8" autocomplete="new-password" required />
          </label>
          <label class="form-field">
            <span>Confirm new password</span>
            <input name="passwordConfirmation" type="password" minlength="8" autocomplete="new-password" required />
          </label>
          <button class="primary-button" type="submit">Update password</button>
        </form>
      </section>
    )}
  </div>
</Base>
