---
interface Props { title: string }
const { title } = Astro.props
import '../styles/global.css'
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header><nav aria-label="Primary"><a href="/">Notes</a> <a href="/tasks">Tasks</a> <a href="/content">Content</a> <a href="/workflows/rules">Workflows</a> <a href="/inbox">Inbox</a> <a href="/search">Search</a></nav></header>
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <script>
      document.querySelector('.skip-link')?.addEventListener('click', () => {
        const main = document.getElementById('main')
        if (main) requestAnimationFrame(() => main.focus())
      })
    </script>
  </body>
</html>
