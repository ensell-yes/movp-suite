---
type Props = { title: string; eyebrow?: string }
const { title, eyebrow = 'MOVP CRM-lite' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="A schema-driven CRM built on MOVP." />
    <title>{title}</title>
    <style is:global>
      :root { color: #17251e; background: #f4f1e7; font-family: Georgia, 'Times New Roman', serif; }
      * { box-sizing: border-box; }
      body { margin: 0; min-height: 100vh; background: radial-gradient(circle at 85% 5%, rgba(196,104,53,.18), transparent 30rem), linear-gradient(120deg, #f7f3e8, #e9efe5); }
      main { width: min(1080px, calc(100% - 2rem)); margin: 0 auto; padding: 3rem 0 5rem; }
      nav { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 4rem; }
      nav a { color: #244c38; font: 700 .78rem/1.2 ui-monospace, monospace; text-transform: uppercase; }
      .eyebrow { color: #a64f2b; font: 700 .75rem/1 ui-monospace, monospace; letter-spacing: .14em; text-transform: uppercase; }
      h1 { max-width: 14ch; margin: .65rem 0 2rem; font-size: clamp(2.5rem, 8vw, 6rem); line-height: .92; font-weight: 500; }
      table { width: 100%; border-collapse: collapse; background: rgba(255,255,255,.68); box-shadow: 0 18px 60px rgba(27,48,36,.08); }
      th, td { padding: .9rem 1rem; border-bottom: 1px solid #ccd7cc; text-align: left; }
      th { font: 700 .72rem/1 ui-monospace, monospace; letter-spacing: .08em; text-transform: uppercase; }
      .error { padding: 1rem; border-left: .25rem solid #a64f2b; background: #fff7ed; }
      .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr)); gap: 1rem; }
      .card { min-height: 12rem; padding: 1.25rem; color: inherit; background: rgba(255,255,255,.65); border: 1px solid #cdd8cd; text-decoration: none; }
      .card strong { display: block; margin-top: 4rem; font-size: 1.4rem; }
    </style>
  </head>
  <body>
    <main>
      <nav><a href="/">Overview</a><a href="/contacts">Contacts</a><a href="/companies">Companies</a><a href="/deals">Deals</a></nav>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <slot />
    </main>
  </body>
</html>

